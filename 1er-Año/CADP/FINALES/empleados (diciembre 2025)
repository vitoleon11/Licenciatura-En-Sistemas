{Una empresa dispone de una estructura de datos con información de sus empleados. De cada empleado conoce su nombre, año de nacimiento y salario,
 y la información se encuentra ordenada por año de nacimiento. Realizar un programa que informe los 10 años en los que nacieron más empleados, 
 y el monto total destinado al pago de salarios de dichos empleados nacidos en esos 10 años.
}
program final;
const
    dimF = 10;
type
    empleado = record
        nombre:string;
        anio:integer;
        salario:real;
    end;

    maxAnio = record
        anio:integer;
        cant:integer;
        salarioTotal:real;
    end;

    lista = ^nodo; // SE DISPONE ORDENADA POR AÑO
    nodo = record
        dato:empleado;
        sig:lista;
    end;

    vector = array [1..dimF] of maxAnio;

    procedure cargarLista(var l :lista); //se dispone 

    procedure insertarOrdenado(var v:vector;var dimL:integer; a:maxAnio);
    var
        i:integer;
    begin
        i := dimL;
        while (i >= 1) and (v[i].cant > a.cant) do begin
            v[i+1] := v[i];
            i := i - 1;
        end;
        v[i+1] := a;
        dimL := dimL + 1;
    end;
procedure eliminarPrimero(var v:vector;var dimL:integer);
    var
        i:integer;
    begin
        for i := 1 to dimL -1 do begin
            v[i] := v[i+1];
        end;
        dimL := dimL - 1;
    end;

    procedure cargarVector(l:lista;var v:vector;var dimL:integer);
    var
        anioActual,cantE:integer;
        a:maxAnio;
        salario : real;
    begin
        while (l <> nil) do begin
            anioActual := l^.dato.anio;
            cantE := 0;
            salario := 0;
            while (l <> nil) and (anioActual = l^.dato.anio) do begin 
                 cantE := cantE + 1;
                 salario := salario + l^.dato.salario;
                 l := l^.sig;
            end;
            a.anio := anioActual;
            a.cant := cantE;
            a.salarioTotal := salario;
            if (dimL < dimF) then
                insertarOrdenado(v,dimL,a)
            else if (a.cant > v[1].cant) then begin
                    eliminarPrimero(v,dimL);
                    insertarOrdenado(v,dimL,a)
                end;
        end;
        for i := 1 to 10 do begin
          writeln('Año: ', v[i].anio, ' Monto total: ' , v[i].salario);
        end;
    end;

var
    l:lista;
    v:vector;
    dimL:integer;
begin
    l := nil;
    cargarLista(l);
    dimL := 0;
    cargarVector(l,v,dimL);
end.
