{
La plataforma de música Spotify desea procesar información de sus artistas. Para ello, dispone de una estructura de datos
con información de los artistas. De cada artista se conoce: nombre, género musical (1: Funk, 2: Pop, 3: Rock, 4: Folklore,
5: Cumbia, 6: Cuarteto, 7: Tango, 8: Electrónica), cantidad de reproducciones de todas sus canciones, y si su perfil 
se encuentra verificado o no.

Se pide realizar un programa que:

a. Informe los códigos de géneros musicales que poseen más artistas con perfil verificado.

b. Informe el porcentaje de artistas Pop en los cuales la suma de los dígitos pares de su 
cantidad de reproducciones es igual que la suma de los dígitos impares.

c. Genere una nueva estructura que almacene los artistas con perfil verificado con menos de 
1 millón de reproducciones.

Nota: la estructura que se dispone se debe recorrer una vez.
}
program parcial;
type
    artista = record
        nombre:string;
        genero:integer;
        reproducciones:integer;
        verificado : boolean;
    end;

    lista = ^nodo; //se dispone
    nodo = record
        dato:artista;
        sig:lista;
    end;

    lista2 = ^nodo2;
    nodo2 = record
        dato: artista;
        sig:lista2;
    end;

    vector = array [1..8] of integer;

    procedure cargarLista(var l :lista); // se dispone

    procedure inicializarVector(var v :vector);
    var
        i:integer;
    begin
        for i:= 1 to 8 do begin
            v[i] := 0;
        end;
    end;

    function igualSuma(num:integer):boolean;
    var
        dig,sumaPar,sumaImpar:integer;
    begin
        sumaPar := 0;
        sumaImpar := 0;
        while (num <> 0) do begin
            dig := num MOD 10;
            if (dig mod 2 = 0) then
                sumaPar := sumaPar + dig
            else
                sumaImpar := sumaImpar + dig;
            num := num div 10;
        end;
        igualSuma := sumaPar = sumaImpar;
    end; 

    procedure agregarAdelante(var l2:lista2;a:artista);
    var
        nue:lista2;
    begin
        new(nue);
        nue^.dato := a;
        nue^.sig := l;
        l := nue;
    end;

    procedure procesarTodo(l:lista;var l2:lista2;var v :vector);
    var
        aux : lista;
        maxCod1,maxCod2,max1,max2,cantTotal,cantSuma,i:integer;
        porcentaje :real;
    begin
        aux := l;
        cantSuma := 0;
        cantTotal := 0;
        while (aux <> nil) do begin
            if aux^.dato.verificado then
                v[aux^.dato.genero] := v[aux^.dato.genero] + 1;
            if (aux^.dato.genero = 2) AND (igualSuma(aux^.dato.reproducciones)) then begin
                cantSuma := cantSuma + 1;
            end;
            if (aux^.dato.verificado) AND (aux^.dato.reproducciones < 1000000) then
                agregarAdelante(l2,aux^.dato);
            cantTotal := cantTotal + 1;
            aux := aux^.sig;
        end;
        max1 := -1;
        max2 := -1;
        for i := 1 to 8 do begin
            if (v[i] > max1) then begin
                max2 := max1;
                maxCod2 := maxCod1;
                max1 := v[i];
                maxCod1 := i;
            end
            else if (v[i] > max2) then begin
                    max2 := v[i];
                    maxCod2 := i;
            end;
        end;
        porcentaje := (cantSuma* 100) / cantTotal;
        writeln('El porcentaje del inciso B es ', porcentaje);
        writeln('Los dos generos con mayor cantidad de reproducciones: ',maxCod1,' y ', maxCod2);
    end;

var
    l:lista;
    v:vector;
begin
    l := nil;
    cargarLista(l);
    inicializarVector(v);
    procesarTodo(l,l2,v);
end.
