program gork;
type
    cliente = record
        numCliente:integer;
        dni:integer;
        monto:real;
    end;

    vector = array [1..500] of cliente; //SE DISPONE

    procedure cargarVector(var v:vector;var dimL:integer); //SE DISPONE

    function capicua(dni:integer):boolean;
    var
        dig,invertido,original:integer;
    begin
        original := dni;
        invertido := 0;
        while (dni <> 0) do begin
            dig := dni MOD 10;
            invertido := invertido * 10 + dig;
            dni := dni div 10;
        end;
        capicua := (original = invertido);
    end;

    procedure informar(v:vector;dimL:integer);
    var
        i,cantTotal:integer;
    begin
        cantTotal := 0;
        for i := 1 to dimL do begin
            if (capicua(v[i].dni)) then 
                cantTotal := cantTotal + 1;
        end;
        writeln('La cantidad total de DNI capicua es ', cantTotal);
    end;

var
    v:vector;
    dimL:integer;
begin 
    dimL := 0;
    cargarVector(v,dimL);
    informar(v,dimL);
end.
