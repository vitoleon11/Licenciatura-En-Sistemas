{Un comercio dispone de una estructura de datos con las facturas (como máximo 2000 facturas) realizadas durante marzo 
de 2023. De cada factura se conoce el número de factura, código de cliente, código de sucursal y monto total. Las facturas 
se encuentran ordenadas por código de sucursal. Se pide implementar un programa con un módulo que reciba la estructura que se
dispone y devuelva el código de sucursal con mayor cantidad de facturas. El programa debe informar el valor retornado por el módulo.}

program final;
type
    factura = record
        numero:integer;
        codCliente:integer;
        codSucursal:integer;
        montoTotal:real;
    end;

    vector = array [1..2000] of factura; // se dispone ORDENADO POR SUCURSAL 

    procedure cargarVector(var v:vector); // se dispone

    function mayorFacturas(v:vector;dimL:integer):integer;
    var
        max,codActual,i,maxCod:integer;
    begin
        i := 1;
        maxCod := -1;
        max := -1;
        while (i <= dimL) do begin
            codActual := v[i].codSucursal;
            cant := 0;
            while (i <= dimL) AND (codActual = v[i].codSucursal) do begin
                cant := cant + 1;
                i := i + 1;
            end;
            if (cant > max) then begin
                max := cant;
                maxCod := codActual;
            end;
        end;
        mayorFacturas := maxCod;
    end;


var
    v:vector;//se dispone
    dimL :integer;
begin
    dimL := 0;
    cargarVector(v);
    mayorFacturas(v,dimL);
end.
