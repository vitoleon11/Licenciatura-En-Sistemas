{Una biblioteca nos ha encargado procesar la información de los préstamos realizados
durante el año 2021. De cada préstamo se conoce el ISBN del libro, el número de socio,
día y mes del préstamo y cantidad de días prestados. Implementar un programa con:
a. Un módulo que lea préstamos y retorne 2 estructuras de datos con la información de
los préstamos. La lectura de los préstamos finaliza con ISBN 0. Las estructuras deben
ser eficientes para buscar por ISBN.
i. En una estructura cada préstamo debe estar en un nodo. Los ISBN repetidos
insertarlos a la derecha.
ii. En otra estructura, cada nodo debe contener todos los préstamos realizados al ISBN.
(prestar atención sobre los datos que se almacenan).
b. Un módulo recursivo que reciba la estructura generada en i. y retorne el ISBN más
grande.
c. Un módulo recursivo que reciba la estructura generada en ii. y retorne el ISBN más
pequeño.
d. Un módulo recursivo que reciba la estructura generada en i. y un número de socio. El
módulo debe retornar la cantidad de préstamos realizados a dicho socio.
e. Un módulo recursivo que reciba la estructura generada en ii. y un número de socio. El
módulo debe retornar la cantidad de préstamos realizados a dicho socio.
f. Un módulo que reciba la estructura generada en i. y retorne una nueva estructura
ordenada ISBN, donde cada ISBN aparezca una vez junto a la cantidad total de veces
que se prestó.
g. Un módulo que reciba la estructura generada en ii. y retorne una nueva estructura
ordenada ISBN, donde cada ISBN aparezca una vez junto a la cantidad total de veces
que se prestó.
h. Un módulo recursivo que reciba la estructura generada en g. y muestre su contenido.
i. Un módulo recursivo que reciba la estructura generada en i. y dos valores de ISBN. El
módulo debe retornar la cantidad total de préstamos realizados a los ISBN
comprendidos entre los dos valores recibidos (incluidos).
j. Un módulo recursivo que reciba la estructura generada en ii. y dos valores de ISBN. El
módulo debe retornar la cantidad total de préstamos realizados a los ISBN
comprendidos entre los dos valores recibidos (incluidos).
}
program final;
type
	prestamo = record
		isbn:integer;
		numSocio:integer;
		dia:integer;
		mes:integer;
		cantDias:integer;
	end;	
	
	presNue = record
		numSocio:integer;
		dia:integer;
		mes:integer;
		cantDias:integer;
	end;
	
	arbol1 = ^nodo1;
	nodo1 = record
		dato:prestamo;
		hi:arbol1;
		hd:arbol1;
	end;
	
	lista = ^nodoLista;
	nodoLista = record
		dato:presNue;
		sig:lista;
	end;
	
	
	arbol2 = ^nodo2;
	nodo2 = record
		isbn:integer;
		l:lista;
		hi:arbol2;
		hd:arbol2;
	end;
	
	regArbol = record
		isbn:integer;
		cant:integer;
	end;
	
	arbol3 = ^nodoArbol3;
	nodoArbol3 = record
		dato: regArbol;
		hi:arbol3;
		hd:arbol3;
	end;
	
	arbol4 = ^nodoArbol4;
	nodoArbol4 = record
		dato:regArbol;
		hi:arbol4;
		hd:arbol4;
	end;
	procedure leerPrestamo(var p :prestamo);
	begin
		readln(p.isbn);
		if (p.isbn <> 0) then begin
			readln(p.numSocio);
			readln(p.dia);
			readln(p.mes);
			readln(p.cantDias);
		end;
	end;
	
	procedure insertarArbol1(var a:arbol1;p:prestamo);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := p;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (p.isbn < a^.dato.isbn) then
				insertarArbol1(a^.hi,p)
			else
				insertarArbol1(a^.hd,p);
	end;
	
	procedure agregarAdelante(var l:lista;p:prestamo);
	var
		nue:lista;
	begin
		new(nue);
		nue^.dato.numSocio := p.numSocio;
		nue^.dato.dia := p.dia;
		nue^.dato.mes := p.mes;
		nue^.dato.cantDias := p.cantDias;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure insertarArbol2(var a:arbol2;p:prestamo);
	begin
		if (a = nil) then begin
			new(a);
			a^.isbn := p.isbn;
			a^.l := nil;
			agregarAdelante(a^.l,p);
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (p.isbn = a^.isbn) then
				agregarAdelante(a^.l,p)
			else if (p.isbn < a^.isbn) then
					insertarArbol2(a^.hi,p)
				else
					insertarArbol2(a^.hd,p);
	end;
	
	procedure cargarArboles(var a1:arbol1;var a2 : arbol2);
	var
		p:prestamo;
	begin
		leerPrestamo(p);
		while (p.isbn <> 0) do begin
			insertarArbol1(a1,p);
			insertarArbol2(a2,p);
		end;
	end;
	
	//INCISO B
	function mayorISBN(a:arbol1):integer;
	begin
		if (a = nil) then	
			mayorISBN := -1
		else if (a^.hd = nil) then
				mayorISBN := a^.dato.isbn
			else
				mayorISBN := mayorISBN(a^.hd);
	end;
	
	// INCISO C
	function menorISBN(a:arbol2):integer;
	begin
		if (a = nil) then	
			menorISBN := -1
		else if (a^.hi = nil) then
				menorISBN := a^.isbn
			else
				menorISBN := menorISBN(a^.hi);
	end;
	
	//INCISO D
	function cantPrestamos1(a:arbol1;num:integer):integer;
	begin
		if (a = nil) then
			cantPrestamos1 := 0
		else if (a^.dato.numSocio = num) then
				cantPrestamos1 := 1 + cantPrestamos1(a^.hi,num) + cantPrestamos1(a^.hd,num)
			else
				cantPrestamos1 := cantPrestamos1(a^.hi,num) + cantPrestamos1(a^.hd,num);
	end;
	//INCISO E
	function contarEnLista(l:lista;num:integer):integer;
	begin
		contarEnLista := 0;
		while (l <> nil) do begin
			if (l^.dato.numSocio = num) then
				contarEnLista := contarEnLista + 1;
			l := l^.sig;
		end;
	end;
	function cantPrestamos2(a:arbol2;num:integer):integer;
	begin
		if (a = nil) then
			cantPrestamos2 := 0
		else
			cantPrestamos2 := contarEnLista(a^.l,num) + cantPrestamos2(a^.hi,num) + cantPrestamos2(a^.hd,num)
	end;
	//INCISO F
	procedure insertarArbol3(var a:arbol3; isbn:integer);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato.isbn := isbn;
			a^.dato.cant := 1;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (isbn = a^.dato.isbn) then
			a^.dato.cant := a^.dato.cant + 1
		else if (isbn < a^.dato.isbn) then
			insertarArbol3(a^.hi, isbn)
		else
			insertarArbol3(a^.hd, isbn);
	end;
	
	procedure cargarArbol3(a:arbol1; var a3:arbol3);
	begin
		if (a <> nil) then begin
			cargarArbol3(a^.hi, a3);
			insertarArbol3(a3, a^.dato.isbn);
			cargarArbol3(a^.hd, a3);
		end;
	end;
	//INCISO G
	
	function contarCantEnLista(l:lista):integer;
	begin
		contarCantEnLista := 0;
		while (l <> nil) do begin
			contarCantEnLista := contarCantEnLista + 1;
			l := l^.sig;
		end;
	end;
	
	procedure insertarArbol4(var a4:arbol4;isbn:integer;l:lista);
	begin
		if (a4 = nil) then begin
			new(a4);
			a4^.dato.isbn := isbn;
			a4^.dato.cant := contarCantEnLista(l);
			a4^.hi := nil;
			a4^.hd := nil;
		end
		else if (isbn < a4^.dato.isbn) then
			insertarArbol4(a4^.hi, isbn,l)
		else
			insertarArbol4(a4^.hd, isbn,l);
	end;

	procedure cargarArbol4(a2:arbol2;var a4:arbol4);
	begin
		if (a2 <> nil) then begin
			cargarArbol4(a2^.hi,a4);
			insertarArbol4(a4,a2^.isbn,a2^.l);
			cargarArbol4(a2^.hd,a4)
		end;
	end;
var
	a1:arbol1;
	a2:arbol2;
	num:integer;
begin
	cargarArboles(a1,a2);
	mayorISBN(a1);
	menorISBN(a2);
	readln(num);
	cantPrestamos1(a1,num);
	cantPrestamos2(a2,num);
end.
