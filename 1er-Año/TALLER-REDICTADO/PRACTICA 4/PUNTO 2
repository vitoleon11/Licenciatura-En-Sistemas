			aumentarEdad := resto + aumentarEdad(a^.hi) + AumentarEdad(a^.hd);
		end;
	end;
	}
	//INCISO B vi 
	
	procedure buscarNombre(a :arbol;nom:string;var ok:boolean);
	begin
		if (a <> nil) then begin
			buscarNombre(a^.hi,nom,ok);
			if (a^.dato.nombre = nom) then
				ok := true;
			buscarNombre(a^.hd,nom,ok);
		end;
	end;
	
	//INCISO B vii
	
	function cantSocios(a:arbol):integer;
	begin
		if (a = nil) then
			cantSocios := 0
		else
			cantSocios := 1 + cantSocios(a^.hi) + cantSocios(a^.hd);
	end; 
	
	//INCISO B viii
	
	function sumaEdades(a:arbol):integer;
	begin
		if (a = nil) then
			sumaEdades := 0
		else
			sumaEdades := a^.dato.edad + sumaEdades(a^.hi) + sumaEdades(a^.hd);
	end;
	
	//INCISO i 
	function devolverMaxSocio(a:arbol):integer;
	begin
		if (a = nil) then
			devolverMaxSocio := -1
		else if (a^.hd = nil) then
			devolverMaxSocio := a^.dato.numSocio
			else
				devolverMaxSocio := devolverMaxSocio(a^.hd);
	end;
	
	//INCISO ii
	function devolverMinNodo(a:arbol):arbol;
	begin
		if (a = nil) then
			devolverMinNodo := nil
		else if (a^.hi = nil) then
				devolverMinNodo := a
			else
				devolverMinNodo := devolverMinNodo(a^.hi);
	end;
	
	//INCISO iii
	function devolverSiExiste(a:arbol;num:integer):boolean;
	begin
		if (a = nil) then
			devolverSiExiste := false
		else if (a^.dato.numSocio = num) then
				devolverSiExiste := true
			else if (a^.dato.numSocio < num) then
					devolverSiExiste := devolverSiExiste(a^.hd,num)
				else
					devolverSiExiste := devolverSiExiste(a^.hi,num);
	end;
	
	//INCISO iv
	function devolverEntreValores(a:arbol;valor1,valor2:integer):integer;
	begin
		if (a = nil) then
			devolverEntreValores := 0
		else if (a^.dato.numSocio >= valor1) and (a^.dato.numSocio <= valor2) then
				devolverEntreValores := 1 + devolverEntreValores(a^.hi,valor1,valor2) + devolverEntreValores(a^.hd,valor1,valor2)
			else if (a^.dato.numSocio < valor1) then
					devolverEntreValores := devolverEntreValores(a^.hd,valor1,valor2)
				else if (a^.dato.numSocio > valor2) then
						devolverEntreValores := devolverEntreValores(a^.hi,valor1,valor2);
	end;
	
var
	a:arbol;
	maxSocio,maxEdad,cantAumentos:integer;
	nombre:string;
	ok:boolean;
begin
	a := nil;
	cargarArbol(a);
	informarCreciente(a);
	informarDecreciente(a);
	maxEdad := -1;
	maxSocio := -1;
	mayorEdad(a,maxEdad,maxSocio);
	cantAumentos := 0;
	aumentarEdad(a,cantAumentos);
	readln(nombre);
	ok := false;
	buscarNombre(a,nombre,ok);
	writeln('La cantidad de socios es: ', cantSocios(a));
	writeln('El promedio de edad de los socios es de: ', sumaEdades(a) / cantSocios(a));
end.
