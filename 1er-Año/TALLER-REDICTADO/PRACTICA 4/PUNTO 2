{En el programa del Ejercicio 1 - Clase 3, incorporar lo necesario para:
i. Informar el número de socio más grande. Debe invocar a un módulo recursivo que
retorne dicho valor.
ii. Informar los datos del socio con el número de socio más chico. Debe invocar a un
módulo recursivo que retorne dicho socio.
iii. Leer un valor entero e informar si existe o no existe un socio con ese valor. Debe
invocar a un módulo recursivo que reciba el valor leído y retornar verdadero o falso.
iv. Leer dos valores e informar la cantidad de socios cuyos códigos se encuentran
comprendidos entre los valores leídos. Debe invocar a un módulo recursivo que reciba
los valores leídos y retorne la cantidad solicitada.}

program practica;
type
	socio = record
		numSocio :integer;
		nombre:string;
		edad:integer;
	end;
	
	arbol = ^nodo;
	nodo = record
		dato:socio;
		hi:arbol;
		hd:arbol;
	end;

	//INCISO A
	procedure leerSocio(var s:socio);
	begin
		readln(s.numSocio);
		if (s.numSocio <> 0) then begin
			readln(s.nombre);
			s.edad := Random(100);
		end;
	end;
	
	procedure insertarAlArbol(var a : arbol;s:socio);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := s;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (s.numSocio < a^.dato.numSocio) then
				insertarAlArbol(a^.hi,s)
			else
				insertarAlArbol(a^.hd,s);
	end;
	
	procedure cargarArbol(var a:arbol);
	var
		s:socio;
	begin
		leerSocio(s);
		while (s.numSocio <> 0) do begin
			insertarAlArbol(a,s);
			leerSocio(s);
		end;
	end;
	
	//INCISO B i 
	
	procedure imprimir(s:socio);
	begin
		writeln('Numero de socio: ', s.numSocio,' Nombre: ', s.nombre,' Edad: ', s.edad);
	end;
	
	procedure informarCreciente(a:arbol);
	begin
		if (a <> nil) then begin
			informarCreciente(a^.hi);
			imprimir(a^.dato);
			informarCreciente(a^.hd);
		end;
	end;
	
	//INCISO B ii
	procedure informarDecreciente(a:arbol);
	begin
		if (a <> nil) then begin
			informarDecreciente(a^.hd);
			imprimir(a^.dato);
			informarDecreciente(a^.hi);
		end;
	end;
	
	//INCISO B iii 
	
	procedure actualizarMaximo(var valorMax:integer;var maxSocio:integer;valor:integer;socioNue:integer);
	begin
		if (valor > valorMax) then begin
			valorMax := valor;
			maxSocio := socioNue;
		end;
	end;
	
	procedure mayorEdad(a:arbol;var maxEdad:integer;var maxSocio:integer);
	begin
		if (a <> nil) then begin
			actualizarMaximo(maxEdad,maxSocio,a^.dato.edad,a^.dato.numSocio);
			mayorEdad(a^.hd,maxEdad,maxSocio);
			mayorEdad(a^.hi,maxEdad,maxSocio);
		end;
	end;
	
	//INCISO B iv
	
	procedure aumentarEdad(a:arbol;var cantAumentos:integer);
	begin
		if (a <> nil) then begin
			if (a^.dato.edad mod 2 = 1) then begin
				a^.dato.edad := a^.dato.edad + 1;
				cantAumentos := cantAumentos + 1;
			end;
			aumentarEdad(a^.hi,cantAumentos);
			aumentarEdad(a^.hd,cantAumentos);
		end;
	end;

