  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  
  proceso recorrerAvenida(ES f:numero)
  comenzar
    repetir 9
      tomarFlores(f)
      mover
    tomarFlores(f)
  fin
  
