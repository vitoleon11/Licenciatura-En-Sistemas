programa ejemplo
procesos
  proceso izquierda
  comenzar
    repetir 3 
      derecha
  fin
  
  proceso tomarFlores(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  
  proceso tomarPapeles(ES p :numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p := p + 1
  fin
  
  proceso escalonFlores(E esc:numero;ES f:numero)
  comenzar
    tomarFlores(f)
    repetir esc
      mover
    tomarFlores(f)
    derecha
    repetir esc
      mover
  fin
  
  proceso escaleraDerechaFlores(E esc:numero; ES f:numero)
  comenzar
    repetir 4
      escalonFlores(esc,f)
      izquierda
      esc := esc - 1
  fin
  
  proceso escaleraIzquierdaFlores(E esc:numero;ES f:numero)
  comenzar
    repetir 4
      escalonFlores(esc,f)
      izquierda
      esc := esc + 1
  fin
  
  proceso escalonPapeles(E esc:numero;ES p:numero)
  comenzar
    tomarPapeles(p)
    repetir esc
      mover
    tomarPapeles(p)
    izquierda
    repetir esc
      mover
  fin
  
  proceso escaleraIzquierdaPapeles(E esc:numero; ES p:numero)
  comenzar
    repetir 4
      escalonPapeles(esc,p)
      derecha
      esc := esc  -1
  fin
  
  proceso escaleraDerechaPapeles(E esc:numero;ES p:numero)
  comenzar
    repetir 4
      escalonPapeles(esc,p)
      derecha
      esc := esc + 1
  fin
areas
