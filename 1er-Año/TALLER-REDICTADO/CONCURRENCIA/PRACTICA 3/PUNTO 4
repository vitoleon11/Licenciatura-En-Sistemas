  proceso moverFlores(ES noHay:boolean;E av,ca:numero)
  comenzar
    BloquearEsquina(10,10)
    Pos(10,10)
    si HayFlorEnLaEsquina
      tomarFlor
    si ~HayFlorEnLaEsquina
      noHay := V
    BloquearEsquina(11,11)
    Pos(11,11)
    LiberarEsquina(10,10)
    depositarFlor
    Pos(av,ca)
    LiberarEsquina(11,11)
  fin
  
