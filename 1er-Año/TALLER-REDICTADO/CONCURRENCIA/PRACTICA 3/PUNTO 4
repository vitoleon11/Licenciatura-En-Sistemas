    avInicial := PosAv
    caInicial := PosCa
    mientras (noHay = F) 
      BloquearEsquina(10,10)
      Pos(10,10)
      si HayFlorEnLaEsquina
        tomarFlor
      si ~HayFlorEnLaEsquina
        noHay := V
      BloquearEsquina(11,11)
      Pos(11,11)
      LiberarEsquina(10,10)
      si HayFlorEnLaBolsa
        depositarFlor
      Pos(avInicial,caInicial)
      LiberarEsquina(11,11)
    termine := V
    EnviarMensaje(id,jefe)
  fin
  
