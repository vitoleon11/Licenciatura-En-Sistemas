programa ejemplo
procesos
  proceso tomarFlores(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  
areas
  cuadrante: AreaPC(2,2,10,10)
  areaJefe: AreaP(1,1,1,1)
  area1: AreaP(2,1,2,1)
  area2: AreaP(3,1,3,1)
  area3: AreaP(4,1,4,1)
  area4: AreaP(5,1,5,1)
robots
  robot florero
  variables
    f,id,avInicial,caInicial,av,ca:numero
    noHay:boolean
  comenzar
    f := 0
    noHay := F
    avInicial := PosAv
    caInicial := PosCa
    RecibirMensaje(id,jefe)
    RecibirMensaje(av,jefe)
    RecibirMensaje(ca,jefe)
    mientras (noHay = F)
      BloquearEsquina(av,ca)
      Pos(av,ca)
      si HayFlorEnLaEsquina
        tomarFlor
        f := f + 1
      si ~HayFlorEnLaEsquina
        noHay := V
      Pos(avInicial,caInicial)
      LiberarEsquina(av,ca)
    EnviarMensaje(id,jefe)
    EnviarMensaje(f,jefe)
  fin
  
  robot fiscal
  variables
    av,ca,id,maxFlores,cantFlores,maxID:numero
  comenzar
    Random(av,2,10)
    Random(ca,2,10)
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    EnviarMensaje(4,r4)
    EnviarMensaje(av,r1)
    EnviarMensaje(ca,r1)
    EnviarMensaje(av,r2)
    EnviarMensaje(ca,r2)
    EnviarMensaje(av,r3)
    EnviarMensaje(ca,r3)
    EnviarMensaje(av,r4)
    EnviarMensaje(ca,r4)
    maxFlores := -1
    repetir 4
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(cantFlores,r1)
      sino
        si (id = 2)
          RecibirMensaje(cantFlores,r2)
        sino
          si (id = 3)
            RecibirMensaje(cantFlores,r3)
          sino
            RecibirMensaje(cantFlores,r4)
      si (cantFlores > maxFlores)
        maxFlores := cantFlores
        maxID := id
    Informar(maxID)
  fin
  
