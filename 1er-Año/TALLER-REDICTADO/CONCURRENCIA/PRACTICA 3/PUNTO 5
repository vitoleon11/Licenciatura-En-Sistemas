areas
  ciudad : AreaC(1,1,100,100)
robots
  robot papelero
  variables
    f,id,av,ca:numero
    noHay,termine:boolean
  comenzar
   
    RecibirMensaje(id,jefe)
    mientras (noHay = F) & (PosCa < 100)
      av := PosAv
      ca := PosCa
      BloquearEsquina(11,11)
      Pos(11,11)
      si HayPapelEnLaEsquina
        tomarPapel
      si ~HayPapelEnLaEsquina
        noHay := V
      Pos(av,ca)
      LiberarEsquina(11,11)
      si HayPapelEnLaBolsa
        depositarPapel
        mover
    si HayPapelEnLaBolsa
      depositarPapel
    EnviarMensaje(id,jefe)
    ca := PosCa
    EnviarMensaje(ca,jefe)
  fin
  
  robot coordinador
  variables
    id,idMax,ca,caMax:numero
  comenzar
    EnviarMensaje(1,p1)
    EnviarMensaje(2,p2)
    EnviarMensaje(3,p3)
    EnviarMensaje(4,p4)
    repetir 4
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(ca,p1)
      sino
        si (id = 2)
          RecibirMensaje(ca,p2)
        sino
          si (id = 3)
            RecibirMensaje(ca,p3)
          sino
            RecibirMensaje(ca,p4)
      si (ca > caMax)
        caMax := ca
        idMax := id
    Informar(idMax)
  fin
  
