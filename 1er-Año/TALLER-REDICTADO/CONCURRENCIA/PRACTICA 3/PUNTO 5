  proceso tomarFlores(ES f: numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  
areas
  ciudad : AreaC(1,1,100,100)
robots
  robot papelero
  variables
    f,id,av,ca:numero
    noHay,termine:boolean
  comenzar
   
    RecibirMensaje(id,jefe)
    mientras (noHay = F) 
      av := PosAv
      ca := PosCa
      BloquearEsquina(11,11)
      Pos(11,11)
      si HayFlorEnLaEsquina
        tomarFlor
      si ~HayFlorEnLaEsquina
        noHay := V
      Pos(av,ca)
      LiberarEsquina(11,11)
      si HayFlorEnLaBolsa
        depositarFlor 
        mover
    EnviarMensaje(id,jefe)
  fin
  
