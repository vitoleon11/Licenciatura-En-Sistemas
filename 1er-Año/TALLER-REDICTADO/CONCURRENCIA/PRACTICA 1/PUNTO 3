programa ejemplo
procesos
  proceso izquierda
  comenzar
    repetir 3 
      derecha
  fin
  
  proceso tomarPapeles(ES p:numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p := p + 1 
  fin
  
  proceso tomarFlores(ES f:numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
  fin
  
  proceso limpiarEsquina(ES p :numero; ES f:numero)
  comenzar
    tomarPapeles(p)
    tomarFlores(f)
  fin
  
  proceso limpiarBolsa(E p:numero; E f:numero)
  comenzar
    mientras HayPapelEnLaBolsa
      depositarPapel
    mientras HayFlorEnLaBolsa
      depositarFlor
  fin
  
  proceso hacerEscalon(E esc:numero;ES p:numero; ES f:numero)
  comenzar
    repetir esc
      limpiarEsquina(p,f)
      limpiarBolsa(p,f)
      mover
    derecha
    repetir esc
      limpiarEsquina(p,f)
      limpiarBolsa(p,f)
      mover
    limpiarEsquina(p,f)
    limpiarBolsa(p,f)
  fin
  
areas
  ciudad: AreaC (1,1,100,100)
robots
  robot robot1
  variables
    esc,p,masP,f:numero
  comenzar
    esc := 1
    masP := 0
    repetir 4
      p := 0
      f := 0
      hacerEscalon(esc,p,f)
      si p > (f + 1)
        masP := masP +1
      izquierda
      esc := esc + 1 
    Informar(masP)
  fin
  
