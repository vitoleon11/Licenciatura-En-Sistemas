  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  proceso recorrerAvenidaFlores(ES fEsq: numero; ES sinFlor:numero)
  comenzar
    repetir 99
      si HayFlorEnLaEsquina
        juntarFlores(fEsq)
      sino
        sinFlor := sinFlor + 1
      mover
    si HayFlorEnLaEsquina
      juntarFlores(fEsq)
    sino
      sinFlor := sinFlor + 1
  fin
