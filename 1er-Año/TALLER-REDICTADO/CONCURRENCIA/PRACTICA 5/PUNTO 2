programa ejemplo
procesos
  proceso tomarPapeles(ES p:numero)
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
      p := p + 1
  fin
  
  proceso tomarFlores(ES f:numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin    
  
  proceso enviarMensajes(E id:numero)
  comenzar
    si (id = 1)
      EnviarMensaje(V,r2)
      EnviarMensaje(V,r3)
    sino
      si (id = 2)
        EnviarMensaje(V,r1)
        EnviarMensaje(V,r3)
      sino
        EnviarMensaje(V,r1)
        EnviarMensaje(V,r2)
  fin
  
  proceso depositarFlores(E f:numero;E av:numero;E ca:numero)
  comenzar
    BloquearEsquina(50,50)
    Pos(50,50)
    repetir f 
      depositarFlor
    Pos(av,ca)
    LiberarEsquina(50,50)
  fin
  
areas
  ciudad: AreaC (1,1,100,100)
robots
  robot recolector
  variables
    esquinas,id,f,av,ca:numero
    seguir: boolean
  comenzar
    RecibirMensaje(id,jefe)
    esquinas := 0
    f := 0
    derecha 
    mientras (PosAv <> 100)
      si (esquinas = 10)
        esquinas := 0
        si (f > 0)
          av := PosAv
          ca := PosCa
          depositarFlores(f,av,ca)
          f := 0
        enviarMensajes(id)
        RecibirMensaje(seguir,*)
        RecibirMensaje(seguir,*)
      sino
        tomarFlores(f)    
        mover
        esquinas := esquinas + 1
    tomarFlores(f)
    si (f > 0)
      av := PosAv
      ca := PosCa
      depositarFlores(f,av,ca)
    EnviarMensaje(V,jefe)
  fin
  
  
  robot fiscalizador
  variables 
    juntar:boolean
    f :numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    RecibirMensaje(juntar,*)
    RecibirMensaje(juntar,*)
    RecibirMensaje(juntar,*)
    Pos(50,50)
    f := 0
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
    Informar(f)
  fin
variables
  r1 : recolector
  r2: recolector
  r3: recolector
  jefe: fiscalizador 
comenzar
  AsignarArea(r1, ciudad)
  AsignarArea(r2, ciudad)
  AsignarArea(r3, ciudad)
  AsignarArea(jefe, ciudad)
  Iniciar(r1, 1,1)
  Iniciar(r2, 1,2)
  Iniciar(r3,1,3)  
  Iniciar(jefe, 1,4)
fin
