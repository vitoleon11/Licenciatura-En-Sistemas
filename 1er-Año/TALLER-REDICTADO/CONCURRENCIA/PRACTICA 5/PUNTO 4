programa ejemplo
procesos    
  proceso tomarFlores(ES f:numero; E av:numero;E ca:numero; E avI:numero; E caI:numero)
  comenzar
    BloquearEsquina(av,ca)
    Pos(av,ca)
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
    Pos(avI,caI)
    LiberarEsquina(av,ca)
  fin
   
areas
  ciudad: AreaC (1,1,100,100)
robots
  robot recolector
  variables
    f,caInicial,avInicial,av,ca:numero
  comenzar
    f := 0
    avInicial := PosAv
    caInicial := PosCa
    RecibirMensaje(av,jefe)
    mientras (av <> 0)
      RecibirMensaje(ca,jefe)
      tomarFlores(f,av,ca,avInicial,caInicial)
      RecibirMensaje(av,jefe)
    BloquearEsquina(10,10)
    Pos(10,10)
    repetir f
      depositarFlor
    Pos(avInicial,caInicial)
    LiberarEsquina(10,10)
  fin
  
  
  robot cosechador
  variables 
    id,av,ca,intentos:numero
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    intentos := 0
    mientras (intentos < 8)
      Random(id,1,3)
      Random(av,40,60)
      Random(ca,40,60)
      si (id = 1)
        EnviarMensaje(av,r1)
        EnviarMensaje(ca,r1)
      sino
        si (id = 2)
          EnviarMensaje(av,r2)
          EnviarMensaje(ca,r2)
        sino  
          EnviarMensaje(av,r3)
          EnviarMensaje(ca,r3)
      intentos := intentos + 1
    EnviarMensaje(0,r1)
    EnviarMensaje(0,r2)
    EnviarMensaje(0,r3)
  fin
  
variables
  r1 : recolector
  r2: recolector  
  r3: recolector  
  jefe: cosechador 
comenzar
  AsignarArea(r1, ciudad)
  AsignarArea(r2, ciudad)
  AsignarArea(r3, ciudad)
  AsignarArea(jefe, ciudad)
  Iniciar(r1, 1,1)
  Iniciar(r2,2,1)
  Iniciar(r3,3,1)  
  Iniciar(jefe, 4,1)
fin
