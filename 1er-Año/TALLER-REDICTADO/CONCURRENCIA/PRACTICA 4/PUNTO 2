
programa ejemplo
procesos
  proceso agarrarPapeles(ES p:numero)
  comenzar
    mientras (HayPapelEnLaEsquina) & (p < 5)
      tomarPapel
      p := p + 1
  fin
  
  proceso dejarEn50(E av:numero; E ca:numero)
  comenzar
    BloquearEsquina(50,50)
    Pos(50,50)
    repetir 5
      depositarPapel
    Pos(av,ca)
    LiberarEsquina(50,50)
  fin
  
  proceso contarOJuntarPapeles(E p:numero;E av:numero;E ca:numero;ES intento:boolean)
  variables
    pE:numero
  comenzar
    intento := F
    pE := 0
    BloquearEsquina(50,50)
    Pos(50,50)
    mientras (HayPapelEnLaEsquina) & (pE < p)
      tomarPapel
      pE := pE + 1
    si (pE = p)
      intento := V
    sino
      repetir pE
        depositarPapel
    Pos(av,ca)
    LiberarEsquina(50,50)
  fin
areas
  ciudad: AreaC (1,1,100,100)
robots
  robot productor
  variables
    av,ca,p:numero
  comenzar
    mientras (PosCa <> 100)
      av := PosAv
      ca := PosCa
      agarrarPapeles(p)
      si (p = 5)
        dejarEn50(av,ca)
        p := 0
      sino
        mover
  fin
  robot consumidor
  variables
    p,av,ca,intentosF:numero
    int :boolean
  comenzar
    av := PosAv
    ca := PosCa
    intentosF := 0
    mientras (intentosF < 8)
      Random(p,2,5)
      contarOJuntarPapeles(p,av,ca,int)
      si (int = V)
        repetir p
          depositarPapel
        intentosF := 0
      sino
        intentosF := intentosF + 1
  fin
variables
  p1: productor
  p2:productor
  c1:consumidor
  c2:consumidor
comenzar
  AsignarArea(p1, ciudad)
  AsignarArea(p2, ciudad)
  AsignarArea(c1, ciudad)
  AsignarArea(c2, ciudad)
  Iniciar(p1,10,1)
  Iniciar(p2,5,1)
  Iniciar(c1,11,1)
  Iniciar(c2,12,1)
fin
