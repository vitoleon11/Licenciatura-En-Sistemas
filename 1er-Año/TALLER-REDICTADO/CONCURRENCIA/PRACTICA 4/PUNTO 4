programa ejemplo
procesos
  proceso tomarPapeles
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
  fin
  
  proceso tomarFlores
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
  fin  
  
  proceso vaciarBolsa
  comenzar
    mientras HayFlorEnLaBolsa
      depositarFlor
    mientras HayPapelEnLaBolsa
      depositarPapel
  fin  
  
  proceso tarea1(E av:numero; E ca:numero;E avI:numero;E caI:numero)
  comenzar
    BloquearEsquina(av,ca)
    Pos(av,ca)
    tomarFlores
    Pos(avI,caI)
    LiberarEsquina(av,ca)
  fin
  
  proceso tarea2(E av:numero;E ca:numero;E avI:numero;E caI:numero)
  comenzar
    BloquearEsquina(av,ca)
    Pos(av,ca)
    tomarPapeles
    Pos(avI,caI)
    LiberarEsquina(av,ca)
  fin
  
  proceso tarea3(E av:numero; E ca:numero; E avI:numero;E caI:numero)
  comenzar
    BloquearEsquina(av,ca)
    Pos(av,ca)
    vaciarBolsa
    Pos(avI,caI)
    LiberarEsquina(av,ca)
  fin
  
areas
  cuadrante: AreaPC (2,2,100,100)
  area1 : AreaP(2,1,2,1)
  area2 : AreaP(3,1,3,1)
  areaJefe: AreaP(1,1,1,1)
robots
  robot trabajador
  variables
    tarea,av,ca,avInicial,caInicial:numero
  comenzar
    avInicial := PosAv
    caInicial := PosCa
    RecibirMensaje(tarea,jefe)
    mientras (tarea <> 4)
      RecibirMensaje(av,jefe)
      RecibirMensaje(ca,jefe)
      si (tarea = 1)
        tarea1(av,ca,avInicial,caInicial)
      sino
        si (tarea = 2)
          tarea2(av,ca,avInicial,caInicial)
        sino
          tarea3(av,ca,avInicial,caInicial)
      RecibirMensaje(tarea,jefe)
  fin
  
  robot coordinador
  variables
    av,ca,tarea,t,avInicial,caInicial:numero
  comenzar
    repetir 10
      Random(tarea,1,3)
      Random(av,2,100)
      Random(ca,2,100)
      Random(t,1,2)
      si (t = 1)
        EnviarMensaje(tarea,t1)
        EnviarMensaje(av,t1)
        EnviarMensaje(ca,t1)
      sino
        EnviarMensaje(tarea,t2)
        EnviarMensaje(av,t2)
        EnviarMensaje(ca,t2)
    EnviarMensaje(4,t1)
    EnviarMensaje(4,t2)
  fin
variables
  t1 : trabajador
  t2:trabajador
  jefe:coordinador
comenzar
  AsignarArea(t1, cuadrante)
  AsignarArea(t2, cuadrante)
  AsignarArea(jefe, areaJefe)
  AsignarArea(t1, area1)
  AsignarArea(t2, area2)
  Iniciar(t1, 2,1)
  Iniciar(t2, 3,1)
  Iniciar(jefe, 1,1)
fin
