programa ejemplo
procesos
  proceso depositarFlorBase
  comenzar
    BloquearEsquina(12,11)
    Pos(12,11)
    depositarFlor
    Pos(11,12)
    LiberarEsquina(12,11)
  fin
  
  proceso buscarFlorBase
  variables
    av:numero
  comenzar
    av := PosAv
    BloquearEsquina(12,11)
    Pos(12,11)
    tomarFlor
    Pos(av+1,12)
    LiberarEsquina(12,11)
  fin
  
  proceso depositarPapelBase
  comenzar
    BloquearEsquina(12,11)
    Pos(12,11)
    depositarPapel
    Pos(11,10)
    LiberarEsquina(12,11)
  fin
  
  proceso buscarPapelBase
  variables
    av:numero
  comenzar
    av := PosAv
    BloquearEsquina(12,11)
    Pos(12,11)
    tomarPapel
    Pos(av+1,10)
    LiberarEsquina(12,11)
  fin
  
areas
  areaFuenteFlores: AreaP (10,12,10,12)
  areaFuentePapeles: AreaP (10,10,10,10)
  
  areaRecolectorAzul: AreaP (11,12,11,12)
  areaDepositadorAzul: AreaP (12,12,20,12)
  
  areaRecolectorVerde: AreaP (11,10,11,10)
  areaDepositadorVerde: AreaP (12,10,20,10)
  
  areaBase: AreaC (12,11,12,11)
robots
  robot recA
  variables
    seguir:boolean
  comenzar
    RecibirMensaje(seguir,da)
    mientras (seguir = V)
      Pos(10,12)
      tomarFlor
      depositarFlorBase
      EnviarMensaje(V,da)
      RecibirMensaje(seguir,da)
  fin
  
  robot depA
  variables
    agarrar:boolean
  comenzar
    derecha
    mientras (PosAv <> 20)
      EnviarMensaje(V,ra)
      RecibirMensaje(agarrar,ra)
      buscarFlorBase
    EnviarMensaje(F,ra)
  fin
  
  robot recV
  variables
    seguir:boolean
  comenzar
    RecibirMensaje(seguir,dv)
    mientras (seguir = V)
      Pos(10,10)
      tomarPapel
      depositarPapelBase
      EnviarMensaje(V,dv)
      RecibirMensaje(seguir,dv)
  fin
  
  robot depV
  variables
    agarrar:boolean
  comenzar
    derecha
    mientras (PosAv <> 20)
      EnviarMensaje(V,rv)
      RecibirMensaje(agarrar,rv)
      buscarPapelBase
    EnviarMensaje(F,rv)
  fin
  
variables
  ra: recA
  da: depA
  rv: recV
  dv: depV
comenzar
  AsignarArea(ra, areaRecolectorAzul)
  AsignarArea(da, areaDepositadorAzul)
  
  AsignarArea(rv, areaRecolectorVerde)
  AsignarArea(dv, areaDepositadorVerde)
  
  AsignarArea(ra, areaFuenteFlores)
  AsignarArea(rv, areaFuentePapeles)
  
  AsignarArea(ra, areaBase)
  AsignarArea(da, areaBase)
  AsignarArea(rv, areaBase)
  AsignarArea(dv, areaBase)
  
  Iniciar(ra, 11,12)
  Iniciar(da, 12,12)
  Iniciar(rv, 11,10)
  Iniciar(dv, 12,10)
fin
