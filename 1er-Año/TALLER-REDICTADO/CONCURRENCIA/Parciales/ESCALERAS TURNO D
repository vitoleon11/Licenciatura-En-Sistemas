programa ejemplo
procesos

  proceso izquierda
  comenzar
    repetir 3
      derecha
  fin

  proceso tomarFlores(ES f:numero)
  comenzar
    mientras HayFlorEnLaEsquina
      tomarFlor
      f := f + 1
  fin
  
  proceso dejarDeAUna(E f:numero; E av:numero; E ca:numero)
  comenzar
    repetir f
      BloquearEsquina(1,5)
      Pos(1,5)
      depositarFlor
      Pos(av,ca)
      LiberarEsquina(1,5)
  fin
  
  proceso hacerEscalon(ES f:numero;E alto:numero;E ancho:numero)
  comenzar
    repetir alto
      tomarFlores(f)
      mover
    derecha
    repetir ancho
      tomarFlores(f)
      mover
    tomarFlores(f)
  fin  
areas
  ciudad: AreaC (1,1,100,100)
robots
  robot robotA
  variables
    alto,ancho,escalones,av,ca,f,av2,ca2,id,fTotales:numero
  comenzar
    RecibirMensaje(id,jefe)
    Random(alto,2,5)
    Random(ancho,2,5) 
    escalones := 0
    mientras (escalones < 2)
      f := 0
      hacerEscalon(f,alto,ancho)
      escalones := escalones + 1
      izquierda
      av := PosAv
      ca := PosCa
      EnviarMensaje(av,RB)
      EnviarMensaje(ca,RB)
      si (f > 0)
        dejarDeAUna(f,av,ca)
      si (escalones < 2)
        RecibirMensaje(av,RB)
        RecibirMensaje(ca,RB)
        Pos(av,ca+1)
      fTotales := fTotales + f
    EnviarMensaje(id,jefe)
    EnviarMensaje(fTotales,jefe)
  fin
  
  robot robotB
  variables
    alto,ancho,f,escalones,av,ca,id,fTotales:numero
  comenzar
    RecibirMensaje(id,jefe)
    Random(alto,3,6)
    Random(ancho,3,6)
    escalones := 0
    mientras (escalones < 2)
      f := 0
      RecibirMensaje(av,RA)
      RecibirMensaje(ca,RA)
      Pos(av,ca+1)
      hacerEscalon(f,alto,ancho)
      izquierda
      escalones := escalones + 1
      av := PosAv
      ca := PosCa
      si (escalones < 2)
        EnviarMensaje(av,RA)
        EnviarMensaje(ca,RA)
      si (f > 0)
        dejarDeAUna(f,av,ca)
      fTotales := fTotales + 1
    EnviarMensaje(id,jefe)
    EnviarMensaje(fTotales,jefe)
  fin
  
  robot fiscalizador
  variables
    id,idMax,f,fMax:numero
  comenzar
    EnviarMensaje(1,RA)
    EnviarMensaje(2,RB)
    fMax := -1
    repetir 2  
      RecibirMensaje(id,*)
      si (id = 1)
        RecibirMensaje(f,RA)
      sino
        RecibirMensaje(f,RB)
      si (f > fMax)
        fMax := f
        idMax := id
    si (idMax = 1)
      Informar('El_ganador_es_el_robot_A',idMax)
    sino  
      Informar('El_ganador_es_el_robot_B',idMax)
  fin
variables
  RA: robotA
  RB : robotB
  jefe :fiscalizador
comenzar
  AsignarArea(RA, ciudad)
  AsignarArea(RB, ciudad)
  AsignarArea(jefe, ciudad)
  Iniciar(RA, 2,1)
  Iniciar(RB, 3,1)
  Iniciar(jefe, 4,1)
fin
