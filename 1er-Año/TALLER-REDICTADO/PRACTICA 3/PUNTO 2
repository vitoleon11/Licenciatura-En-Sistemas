{2. Escribir un programa que:
a. Implemente un módulo que genere aleatoriamente información de ventas de un comercio.
Para cada venta generar código de producto, fecha y cantidad de unidades vendidas. Finalizar
con el código de producto 0. Un producto puede estar en más de una venta. Se pide:
i. Generar y retornar un árbol binario de búsqueda de ventas ordenado por código de
producto. Los códigos repetidos van a la derecha.
ii. Generar y retornar otro árbol binario de búsqueda de productos vendidos ordenado por
código de producto. Cada nodo del árbol debe contener el código de producto y la
cantidad total de unidades vendidas.
iii. Generar y retornar otro árbol binario de búsqueda de productos vendidos ordenado
por código de producto. Cada nodo del árbol debe contener el código de producto y la
lista de las ventas realizadas del producto.
 Nota: El módulo debe retornar TRES árboles.
b. Implemente un módulo que reciba el árbol generado en i. y una fecha y retorne la cantidad
total de productos vendidos en la fecha recibida.
c. Implemente un módulo que reciba el árbol generado en ii. y retorne el código de producto
con mayor cantidad total de unidades vendidas. 
c. Implemente un módulo que reciba el árbol generado en iii. y retorne el código de producto
con mayor cantidad de ventas.
 }
program practica;
type
	venta = record
		codProducto:integer;
		fecha:string;
		cantVendidas:integer;
	end;
	
	producto = record
		codProducto : integer;
		cantVendidas:integer;
	end;
	
	prodLista = record
		fecha:string;
		cantVendidas:integer;
	end;
	
	arbol1 = ^nodo1;
	nodo1 = record
		dato:venta;
		hi:arbol1;
		hd:arbol1;
	end;
	
	arbol2 = ^nodo2;
	nodo2 = record
		dato:producto;
		hi:arbol2;
		hd:arbol2;
	end;
	
	lista = ^nodoL;
	nodoL = record
		dato:prodLista;
		sig:lista;
	end;
	
	arbol3 = ^nodo3;
	nodo3 = record
		codProducto:integer;
		l:lista;
		hi:arbol3;
		hd:arbol3;
	end;
	
	//INCISO A i
	
	procedure leerVenta(var v:venta);
	begin
		readln(v.codProducto);
		if (v.codProducto <> 0) then begin
			readln(v.fecha);
			readln(v.cantVendidas);
		end;
	end;
	
	procedure insertarVenta(var a:arbol1;v:venta);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := v;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (v.codProducto < a^.dato.codProducto) then
				insertarVenta(a^.hi,v)
			else
				insertarVenta(a^.hd,v);
	end;
	
	
	//INCISO A ii
	
	procedure insertarArbol2(var a:arbol2;v:venta);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato.codProducto := v.codProducto;
			a^.dato.cantVendidas := v.cantVendidas;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (v.codProducto = a^.dato.codProducto) then
				a^.dato.cantVendidas := a^.dato.cantVendidas + v.cantVendidas
			else if (v.codProducto < a^.dato.codProducto) then
					insertarArbol2(a^.hi,v)
				else
					insertarArbol2(a^.hd,v);
	end;
	
	// INCISO A iii
	
	procedure agregarAdelante(var l:lista;v:venta);
	var
		nue:lista;
	begin
		new(nue);
		nue^.dato.fecha := v.fecha;
		nue^.dato.cantVendidas := v.cantVendidas;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure insertarArbol3(var a:arbol3;v:venta);
	begin
		if (a = nil) then begin
			new(a);
			a^.codProducto := v.codProducto;
			a^.l := nil;
			agregarAdelante(a^.l,v);
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (v.codProducto = a^.codProducto) then
				agregarAdelante(a^.l,v)
			else if (v.codProducto < a^.codProducto) then
					insertarArbol3(a^.hi,v)
				else
					insertarArbol3(a^.hd,v);
	end;
	
	procedure cargarArboles(var a1:arbol1;var a2:arbol2;var a3:arbol3);
	var
		v:venta;
	begin
		leerVenta(v);
		while (v.codProducto <> 0) do begin
			insertarVenta(a1,v);
			insertarArbol2(a2,v);
			insertarArbol3(a3,v);
			leerVenta(v);
		end;
	end;
	
	// INCISO b
	
	function devolverFecha(a:arbol1;fecha:string):integer;
	begin
		if (a = nil) then
			devolverFecha := 0
		else if (fecha = a^.dato.fecha) then
				devolverFecha := a^.dato.cantVendidas + devolverFecha(a^.hi,fecha) + devolverFecha(a^.hd,fecha)
			else
				devolverFecha := devolverFecha(a^.hi,fecha) + devolverFecha(a^.hd,fecha);
	end; 
	
	//INCISO C i
	
	procedure actualizarMaximo(var max:integer;var maxCod:integer;cant,cod:integer);
	begin
		if (cant > max) then begin
			max := cant;
			maxCod := cod;
		end;
	end;
	
	procedure maxCodigo(a:arbol2;var max:integer;var maxCod:integer);
	begin
		if (a <> nil) then begin
			actualizarMaximo(max,maxCod,a^.dato.cantVendidas,a^.dato.codProducto);
			maxCodigo(a^.hi,max,maxCod);
			maxCodigo(a^.hd,max,maxCod);
		end;
	end;
	
	//INCISO C ii
	procedure actualizarMaximoLista(l:lista; var max:integer; var maxCod:integer;cod:integer);
	var
		cant:integer;
	begin
		cant := 0;
		while (l <> nil) do begin
			cant := cant + 1;
			l := l^.sig;
		end;
		if (cant > max) then begin
			max := cant;
			maxCod := cod;
		end;
	end;
	
	procedure maxCodigoArbol3(a:arbol3;var max:integer;var maxCod:integer);
	begin
		if (a <> nil) then begin
			actualizarMaximoLista(a^.l,max,maxCod,a^.codProducto);
			maxCodigoArbol3(a^.hi,max,maxCod);
			maxCodigoArbol3(a^.hd,max,maxCod);
		end;
	end;
	
var
	a1:arbol1;
	a2:arbol2;
	a3:arbol3;
	fecha:string;
	max,maxCod:integer;
begin
	a1 := nil;
	a2 := nil;
	a3 := nil;
	cargarArboles(a1,a2,a3);
	readln(fecha);
	devolverFecha(a1,fecha);
	max := -1; maxCod := -1;
	maxCodigo(a2,max,maxCod);
