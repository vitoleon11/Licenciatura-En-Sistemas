{.- Una librería requiere el procesamiento de la información de sus productos. De cada
producto se conoce el código del producto, código de rubro (del 1 al 6) y precio.
Implementar un programa que invoque a módulos para cada uno de los siguientes puntos:
a. Lea los datos de los productos y los almacene ordenados por código de producto y
agrupados por rubro, en una estructura de datos adecuada. El ingreso de los productos finaliza
cuando se lee el precio -1.
b. Una vez almacenados, muestre los códigos de los productos pertenecientes a cada rubro.
c. Genere un vector (de a lo sumo 20 elementos) con los productos del rubro 3. Considerar que
puede haber más o menos de 20 productos del rubro 3. Si la cantidad de productos del rubro 3
es mayor a 20, almacenar los primeros 20 que están en la lista e ignore el resto.
d. Ordene, por precio, los elementos del vector generado en c) utilizando alguno de los dos
métodos vistos en la teoría.
e. Muestre los precios del vector resultante del punto d).
f. Calcule el promedio de los precios del vector resultante del punto d).}
program practica;
type
	rangoRubros = 1..6;
	producto = record
		codProducto:integer;
		codRubro:rangoRubros;
		precio:real;
	end;
	
	lista = ^nodo;
	nodo = record
		dato:producto;
		sig:lista;
	end;
	
	vListas = array [1..6] of lista;
	
	vTres = array [1..20] of producto;
	
	//INCISO A
	
	procedure inicializarVector(var vL:vListas);
	var
		i:integer;
	begin
		for i := 1 to 6 do begin
			vL[i] := nil;
		end;
	end;
	
	procedure leerProducto(var p:producto);
	begin
		readln(p.precio);
		if (p.precio <> -1) then begin
			readln(p.codProducto);
			readln(p.codRubro);
		end;
	end;
	
	procedure insertarOrdenado(var l:lista;p:producto);
	var
		nue,act,ant:lista;
	begin
		new(nue);
		nue^.dato := p;
		act := l;
		ant := l;
		while (act <> nil) and (act^.dato.codProducto < p.codProducto) do begin
			ant := act;
			act := act^.sig;
		end;
		if (act = l) then 
			l := nue
		else
			ant^.sig := nue;
		nue^.sig := act;
	end;
	
	procedure cargarVectorListas(var vL: vListas);
	var
		p:producto;
	begin
		leerProducto(p);
		while (p.precio <> -1) do begin
			insertarOrdenado(vL[p.codRubro],p);
			leerProducto(p);
		end;
	end;
	
	//INCISO B
	
	procedure imprimirCodigosPorRubro(vL:vListas);
	var
		i:integer;
	begin
		for i := 1 to 6 do begin
			writeln('Codigos rubro ', i);
			while (vL[i] <> nil) do begin
				write(vL[i]^.dato.codProducto,' ');
				vL[i] := vL[i]^.sig;
			end;
		end;
	end;
	
	//INCISO C
	procedure agregarAlVector(var vT:vTres;p:producto;var  dimL:integer);
	begin
		dimL := dimL + 1;
		vT[dimL] := p;
	end;
	
	procedure cargarVectorRubro(var vT:vTres;var dimL:integer;vL:vListas);
	begin
		dimL := 0;
		while (vL[3] <> nil) and (dimL < 20) do begin
			agregarAlVector(vT,vL[3]^.dato,dimL);
			vL[3] := vL[3]^.sig;
		end;
	end;
	
	//INCISO D
	
	procedure ordenarVector(var v:vTres;dimL:integer);
	var
		i,j,pos:integer;
		item:producto;
	begin
		for i := 1 to dimL - 1 do begin
			pos := i;
			for j := i+1 to dimL do begin
				if (v[j].precio < v[pos].precio) then pos := j
			end;
			item := v[pos];
			v[pos] := v[i];
			v[i] := item;
		end;
	end;
	
	//INCISO E
	procedure imprimir(v:vTres;dimL:integer);
	var
		i:integer;
	begin
		for i := 1 to dimL do begin
			writeln('Precio ',i ,': ', v[i].precio);
		end;
	end;
	
	//INCISO F
	function promedio(v:vTres;dimL:integer):real;
	var
		precioTotal:real;
		i:integer;
	begin
		precioTotal := 0;
		for i := 1 to dimL do begin
			precioTotal := precioTotal + v[i].precio;
		end;
		promedio := precioTotal / dimL;
	end;
	
var
	vL:vListas;
	vT:vTres;
	dimL: integer;
begin
	inicializarVector(vL);
	cargarVectorListas(vL);
	imprimirCodigosPorRubro(vL);
	cargarVectorRubro(vT,dimL,vL);
	ordenarVector(vT,dimL);
	imprimir(vT,dimL);
	writeln('Promedio: ', promedio(vT,dimL));
end.
