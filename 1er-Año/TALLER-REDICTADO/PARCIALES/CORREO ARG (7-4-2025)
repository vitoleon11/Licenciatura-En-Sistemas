Correo Argentino desea analizar la información de los paquetes enviados
durante 2024. De cada paquete enviado se conoce: código de envío, DNI
del emisor, DNI del receptor, cantidad de objetos en el paquete y peso del
paquete en gramos. Realice un programa que contenga e invoque a:
a. Un módulo que lea la información de paquetes enviados y retorne una
estructura con todos los paquetes leídos. La estructura debe ser eficiente
para buscar por peso del paquete en gramos. La lectura finaliza al leer un
paquete con código de envío 0.
b. Un módulo que reciba la estructura generada en a) y dos valores, y
retorne una lista con todos los paquetes enviados cuyo peso está entre los
dos valores recibidos.
c. Un módulo que reciba la estructura generada en a) y retorne toda la
información del paquete enviado con mayor cantidad de objetos.}
program practica;
type
	paquete = record
		codEnvio:integer;
		dniE:integer;
		dniR:integer;
		cantObjetos:integer;
		peso:real;
	end;
	
	arbol = ^nodoArbol;
	nodoArbol = record
		dato:paquete;
		hi:arbol;
		hd:arbol;
	end;
	
	lista = ^nodoLista;
	nodoLista = record
		dato:paquete;
		sig:lista;
	end;
	
	procedure leerPaquete(var p : paquete);
	begin
		readln(p.codEnvio);
		if (p.codEnvio <> 0) then begin
			readln(p.dniE);
			readln(p.dniR);
			readln(p.cantObjetos);
			readln(p.peso);
		end;
	end;
	
	procedure insertarArbol(var a:arbol;p:paquete);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := p;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (p.peso < a^.dato.peso) then
				insertarArbol(a^.hi,p)
			else
				insertarArbol(a^.hd,p);
	end;
	
	procedure cargarArbol(var a:arbol);
	var
		p:paquete;
	begin
		leerPaquete(p);
		while (p.codEnvio <> 0) do begin
			insertarArbol(a,p);
			leerPaquete(p);
		end;
	end;
	
	procedure agregarAdelante(var l :lista;p:paquete);
	var
		nue:lista;
	begin
		new(nue);
		nue^.dato := p;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure cargarLista(var l :lista;a:arbol;p1,p2:integer);
	begin
		if (a <> nil) then begin
			if (a^.dato.peso >= p1) and (a^.dato.peso <= p2) then begin
				agregarAdelante(l,a^.dato);
				cargarLista(l,a^.hi,p1,p2);
				cargarLista(l,a^.hd,p1,p2);
			end
			else if (a^.dato.peso < p1) then
					cargarLista(l,a^.hd,p1,p2)
				else
					cargarLista(l,a^.hi,p1,p2);
		end;
	end;

	procedure devolverMayor(a:arbol;var p:paquete; var max:integer);
	begin
		if (a <> nil) then begin
			devolverMayor(a^.hi,p,max);
			if (a^.dato.cantObjetos > max) then begin
				max := a^.dato.cantObjetos;
				p := a^.dato;
			end;
			devolverMayor(a^.hd,p,max);
		end;
	end;
	
var
	a:arbol;
	p1,p2,max:integer;
	l:lista;
	p:paquete;
begin
	a := nil;
	l:=nil;
	cargarArbol(a);
	readln(p1);
	readln(p2);
	cargarLista(l,a,p1,p2);
	devolverMayor(a,p,max);
end.
