{Se desea analizar los exámenes finales de una cátedra.
De cada final se conoce: legajo del alumno, nota y fecha del examen. Un mismo alumno puede haber rendido más de un final.
Los exámenes a analizar son todos los que se tomaron entre 2011 y 2024, ambos inclusive. Realice un programa que contenga:

a) Un módulo que lea finales (sin ningún orden preestablecido), hasta leer un examen con legajo -1, y los almacene en una estructura agrupadas por año. 
En cada año los exámenes deben quedar ordenados por nota de manera descendente.

b) Un módulo que reciba la estructura generada en a) y devuelva otra estructura con los exámenes cuya nota sea mayor a un valor recibido por parámetro.
Esta estructura debe ser eficiente para la búsqueda por legajo.

c) Un módulo que reciba la estructura generada en b) y devuelva la cantidad de exámenes que rindió un alumno cuyo legajo se recibe por parámetro.}

program practica;
type
	fecha = record
		dia,mes,anio:integer;
	end;

	final = record
		legajo:integer;
		nota:real;
		fecha:fecha;
	end;

	lista = ^nodoLista;
	nodoLista = record
		dato:final;
		sig:lista;
	end;
	
	vector = array [2011..2024] of lista;
	
	arbol = ^nodoArbol;
	nodoArbol = record
		dato:final;
		hi:arbol;
		hd:arbol;
	end;
	
	procedure inicializarVector(var v:vector);
	var
		i:integer;
	begin
		for i := 2011 to 2024 do begin
			v[i] := nil;
		end;
	end;

	procedure leerFinal(var f:final);
	begin
		readln(f.legajo);
		if (f.legajo <> -1) then begin
			readln(f.nota);
			readln(f.fecha.dia);
			readln(f.fecha.mes);
			readln(f.fecha.anio);
		end;
	end;
	
	procedure insertarOrdenado(var l:lista;f:final);
	var
		nue,act,ant:lista;
	begin
		new(nue);
		nue^.dato := f;
		act := l;
		ant := l;
		while (act <> nil) and (f.nota < act^.dato.nota) do begin
			ant := act;
			act := act^.sig;
		end;
		if (act = ant) then 
			l := nue
		else
			ant^.sig := nue;
		nue^.sig := act;
	end;

	procedure cargarVector(var v:vector);
	var
		f:final;
	begin
		leerFinal(f);
		while (f.legajo <> -1 ) do begin
			insertarOrdenado(v[f.fecha.anio],f);
			leerFinal(f);
		end;
	end;
	
	//INCISO B
	
	procedure insertarArbol(var a:arbol;f:final);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := f;
			a^.hi := nil;
			a^.hd := nil;
		end 
		else if (f.legajo <= a^.dato.legajo) then
				insertarArbol(a^.hi,f)
			else
				insertarArbol(a^.hd,f);
	end;
	
	procedure recorrerLista(var a:arbol;l:lista;nota:real);
	begin
		while (l <> nil) do begin
			if (l^.dato.nota > nota) then
				insertarArbol(a,l^.dato);
			l := l^.sig;
		end;
	end;
	
	procedure cargarArbol(var a:arbol ;v:vector;nota:real);
	var
		i:integer;
	begin
		for i := 2011 to 2024 do begin
			recorrerLista(a,v[i],nota);
		end;
	end;
	
	//INCISO C
	function cantLegajos(a:arbol;legajo:integer):integer;
	begin
		if (a = nil) then
			cantLegajos := 0
		else if (a^.dato.legajo = legajo) then
				cantLegajos := 1+ cantLegajos(a^.hi,legajo) + cantLegajos(a^.hd,legajo)
			else if (legajo < a^.dato.legajo) then
					cantLegajos := cantLegajos(a^.hi,legajo)
				else
					cantLegajos := cantLegajos(a^.hd,legajo);
	end;
var
	v:vector;
begin
	inicializarVector(v);
	cargarVector(v);
end.
