{Se lee información de las compras realizadas por los clientes a un supermercado en el año 2024.

De cada compra se lee: código de cliente, día, número de mes y monto gastado.
La lectura finaliza cuando se lee el cliente con código 0.

a)
Realizar un módulo que lea la información de las compras y retorne un árbol binario de búsqueda ordenado por código de cliente.
Para cada código de cliente, se debe almacenar un vector con el monto total gastado por dicho cliente en cada mes del año 2024.

b)
Realizar un módulo que reciba la estructura generada en a) y un código de cliente, y retorne el mes con mayor gasto de dicho cliente.

c)
Realizar un módulo que reciba la estructura generada en a) y un número de mes, y retorne la cantidad de clientes que no gastaron nada en dicho mes.}
program practica;
type
	compra = record
		codCliente:integer;
		dia:integer;
		mes:integer;
		monto:real;
	end;
	
	vector = array [1..12] of real;
	
	arbol = ^nodoArbol; //POR CODIGO DE CLIENTE
	nodoArbol = record
		codCliente:integer;
		v:vector;
		hi:arbol;
		hd:arbol;
	end;
	
	procedure inicializarVector(var v:vector);
	var
		i:integer;
	begin
		for i := 1 to 12 do begin
			v[i] := 0;
		end;
	end;	
	
	procedure leerCompra(var c:compra);
	begin
		readln(c.codCliente);
		if (c.codCliente <> 0) then begin
			readln(c.dia);
			readln(c.mes);
			readln(c.monto);
		end;
	end;
	
	procedure insertarArbol(var a:arbol;c:compra);
	begin
		if (a = nil) then begin
			new(a);
			a^.codCliente := c.codCliente;
			inicializarVector(a^.v);
			a^.v[c.mes] := a^.v[c.mes] + c.monto;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (c.codCliente = a^.codCliente) then
				a^.v[c.mes] := a^.v[c.mes] + c.monto
			else if (c.codCliente < a^.codCliente) then
					insertarArbol(a^.hi,c)
				else
					insertarArbol(a^.hd,c);
	end;
	
	procedure cargarArbol(var a:arbol);
	var
		c:compra;
	begin
		leerCompra(c);
		while (c.codCliente <> 0) do begin
			insertarArbol(a,c);
			leerCompra(c);
		end;
	end;
	
	//INCISO B
	
	function mesMayorGasto(v:vector):integer;
	var
		i:integer;
		max:real;
	begin
		max := -1;
		for i := 1 to 12 do begin
			if (v[i] > max) then begin
				max := v[i];
				mesMayorGasto := i;
			end;
		end;
	end;
	
	function devolverMayorMes(a:arbol;cod:integer):integer;
	begin
		if (a = nil) then
			devolverMayorMes := -1
		else if (cod < a^.codCliente) then
				devolverMayorMes := devolverMayorMes(a^.hi,cod)
			else if (cod > a^.codCliente) then
					devolverMayorMes := devolverMayorMes(a^.hd,cod)
				else
					devolverMayorMes := mesMayorGasto(a^.v);
	end;
	
	//INCISO C
	
	function devolverCantClientes(a:arbol;mes:integer):integer;
	begin
		if (a = nil) then 
			devolverCantClientes := 0
		else if (a^.v[mes] = 0) then
				devolverCantClientes := 1 + devolverCantClientes(a^.hi,mes) + devolverCantClientes(a^.hd,mes)
			else
				devolverCantClientes := devolverCantClientes(a^.hi,mes) + devolverCantClientes(a^.hd,mes);
	end;
var
	a:arbol;
	cod,mes:integer;
begin
	cargarArbol(a);
	readln(cod);
	writeln('El mayor mes del cliente es: ',devolverMayorMes(a,cod));	
	readln(mes);
	writeln('Cant clientes que no vendieron: ',devolverCantClientes(a,mes));
end.
