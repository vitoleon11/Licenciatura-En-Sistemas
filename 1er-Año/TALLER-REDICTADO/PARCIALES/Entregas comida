{Una empresa gastronómica requiere el procesamiento de las entregas de comida realizadas a sus clientes durante el mes de mayo de 2025.

a) Implementar un módulo que lea entregas de comidas. De cada compra se lee código de comida, código de cliente, día y categoría de la entrega (1 a 5). 
La lectura finaliza con el código de cliente 0. Se sugiere utilizar el módulo leerEntrega(). Se deben retornar 2 estructuras de datos:

i. Un árbol binario de búsqueda ordenado por código de comida. Para cada código de comida deben almacenarse las entregas realizadas a ese código.

ii. Un vector que almacene, para cada categoría, la cantidad de entregas realizadas.

b) Implementar un módulo que reciba el árbol generado en a) y dos códigos de comida y un valor entero. 
El módulo debe retornar la cantidad de entregas realizadas al cliente con dni igual al valor ingresado para comidas con códigos entre los dos códigos ingresados (sin incluir).

c) Implementar un módulo recursivo que reciba el vector generado en a) ii y un valor entero. El módulo debe retornar si existe o no una categoría con cantidad de entregas igual al valor ingresado.}

program practica;
type
	rangoCat = 1..5;
	
	compra = record
		codComida:integer;
		codCliente:integer;
		dia:integer;
		categoria:rangoCat;
	end;
	
	entrega = record
		codCliente:integer;
		dia:integer;
		categoria:rangoCat;
	end;
	
	lista = ^nodoLista;
	nodoLista = record
		dato:entrega;
		sig:lista;
	end;
	
	arbol = ^nodoArbol;
	nodoArbol = record
		codComida :integer;
		l:lista;
		hi:arbol;
		hd:arbol;
	end;
	
	vector = array [1..5] of integer;
	
	procedure inicializarVector(var v:vector);
	var
		i:integer;
	begin
		for i := 1 to 5 do begin
			v[i] := 0;
		end;
	end;
	
	procedure leerCompra(var c:compra);
	begin
		readln(c.codCliente);
		if (c.codCliente <> 0) then begin
			readln(c.codComida);
			readln(c.dia);
			readln(c.categoria);
		end;
	end;


	procedure agregarAdelante(var l :lista;c:compra);
	var
		nue:lista;
	begin
		new(nue);
		nue^.dato.codCliente := c.codCliente;
		nue^.dato.dia := c.dia;
		nue^.dato.categoria := c.categoria;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure insertarArbol(var a:arbol;c:compra);
	begin
		if (a = nil) then begin
			new(a);
			a^.codComida := c.codComida;
			a^.l := nil;
			agregarAdelante(a^.l,c);
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (c.codComida = a^.codComida) then
				agregarAdelante(a^.l,c)
			else if (c.codComida < a^.codComida) then
					insertarArbol(a^.hi,c)
				else
					insertarArbol(a^.hd,c);
	end;
	
	procedure cargarArbolYVector(var a:arbol;var v:vector);
	var
		c:compra;
	begin
		leerCompra(c);
		while (c.codCliente <> 0) do begin
			insertarArbol(a,c);
			v[c.categoria] := v[c.categoria] + 1;
			leerCompra(c);
		end;
	end;

	//INCISO B
	
	function contarEnListaCod(l:lista;codCliente:integer):integer;
	begin
		contarEnListaCod := 0;
		while (l <> nil) do begin
			if (l^.dato.codCliente = codCliente) then
				contarEnListaCod := contarEnListaCod +1;
			l := l^.sig;
		end;
	end;
	
	function devolverCant(a:arbol;c1,c2,codCliente:integer):integer;
	begin
		if (a = nil) then
			devolverCant := 0
		else if (a^.codComida > c1) and (a^.codComida < c2) then 
				devolverCant := contarEnListaCod(a^.l,codCliente) + devolverCant(a^.hi,c1,c2,codCliente) + devolverCant(a^.hd,c1,c2,codCliente)
			else if (a^.codComida <= c1) then
					devolverCant := devolverCant(a^.hd,c1,c2,codCliente) 
				else
					devolverCant := devolverCant(a^.hi,c1,c2,codCliente);
	end;

	//INCISO C


	function devolverSiEsta(v:vector;valor:integer;i:integer):boolean;
	begin
		if (i > 5) then
			devolverSiEsta := false
		else begin
			if (v[i] = valor) then
				devolverSiEsta := true;
			devolverSiEsta := devolverSiEsta(v,valor,i+1);
		end;
	end;

var
	a:arbol;
	v:vector;
	valor,c1,c2,codC:integer;
begin
	a := nil;
	inicializarVector(v);
	cargarArbolYVector(a,v);
	readln(c1);
	readln(c2);
	readln(codC);
	devolverCant(a,c1,c2,codC);
	readln(valor);
	devolverSiEsta(v,valor,1);
end.
