{Se desea procesar las ventas de una ferretería. De cada venta se conoce CUIL del cliente, monto de la compra y fecha de la compra. Un cliente puede hacer más de una compra, 
incluso en el mismo día. Realice un programa que contenga:

a) Un módulo que lea ventas, hasta leer una venta con CUIL -1, y las almacene en una estructura agrupada por mes. En cada mes las ventas deben quedar ordenadas por CUIL 
y debe ser eficiente para la búsqueda.

b) Un módulo que reciba la estructura generada en a) y devuelva otra estructura con las ventas cuyo monto de compra sea mayor a un valor recibido por parámetro. 
Esta estructura debe ser eficiente para la búsqueda por año.

c) Un módulo que reciba la estructura generada en b) y devuelva la cantidad de ventas por mes realizadas en un rango de años recibidos por parámetro.}

program practica;
type
	
	rFecha = record
		dia,mes,anio:integer;
	end;

	venta = record
		cuil:integer;
		monto:real;
		fecha:rFecha;
	end;
	
	arbol = ^nodoArbol;
	nodoArbol = record
		dato:venta;
		hi:arbol;
		hd:arbol;
	end;
	
	vector = array [1..12] of arbol;
	
	arbol2 = ^nodoArbol2;
	nodoArbol2 = record
		dato:venta;
		hi:arbol2;
		hd:arbol2;
	end;
	
	vContador = array [1..12] of integer;
	
	procedure inicializarContador(var v:vContador);
	var
		i:integer;
	begin
		for i := 1 to 12 do begin
			v[i] := 0;
		end;
	end;
	
	procedure leerVenta(var v:venta);
	begin
		readln(v.cuil);
		if (v.cuil <> -1) then begin
			readln(v.monto);
			readln(v.fecha.dia);
			readln(v.fecha.mes);
			readln(v.fecha.anio);
		end;
	end;
	
	procedure inicializarVector(var v:vector);
	var
		i:integer;
	begin
		for i := 1 to 12 do begin
			v[i] := nil;
		end;
	end;
	
	procedure insertarArbol(var a:arbol;v:venta);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := v;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (v.cuil <= a^.dato.cuil) then
				insertarArbol(a^.hi,v)
			else
				insertarArbol(a^.hd,v);
	end;
	
	procedure cargarVector(var v:vector);
	var
		vt:venta;
	begin
		leerVenta(vt);
		while (vt.cuil <> -1) do begin
			insertarArbol(v[vt.fecha.mes],vt);
			leerVenta(vt);
		end;
	end;
	
	//INCISO B
	
	procedure insertarArbol2(var a:arbol2;v:venta);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := v;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (v.fecha.anio <= a^.dato.fecha.anio) then
				insertarArbol2(a^.hi,v)
			else
				insertarArbol2(a^.hd,v);
	end;
	
	procedure recorrerArbol(a:arbol;var a2:arbol2;valor:integer);
	begin
		if (a <> nil) then begin
			recorrerArbol(a^.hi,a2,valor);
			if (a^.dato.monto > valor) then
				insertarArbol2(a2,a^.dato);
			recorrerArbol(a^.hd,a2,valor);
		end;
	end;
	
	procedure cargarArbol2(v:vector;var a:arbol2;valor:integer);
	var
		i:integer;
	begin
		for i := 1 to 12 do begin
			recorrerArbol(v[i],a,valor);
		end;
	end;
	//INCISO C
	
	procedure devolverCantidadPorMes(a:arbol2;var vC:vContador;a1,a2:integer);
	begin
		if (a <> nil) then begin
			if (a^.dato.fecha.anio >= a1) and (a^.dato.fecha.anio <= a2) then
				vC[a^.dato.fecha.mes] := vC[a^.dato.fecha.mes] + 1;
			if (a^.dato.fecha.anio >= a1) then
				devolverCantidadPorMes(a^.hi, vC, a1, a2);
			if (a^.dato.fecha.anio <= a2) then
				devolverCantidadPorMes(a^.hd, vC, a1, a2);
			end;
	end;
	
var
	v:vector;
	a2:arbol2;
	valor:integer;
begin
	inicializarVector(v);
	cargarVector(v);
	a2 := nil;
	readln(valor);
	cargarArbol2(v,a2,valor);
end.
