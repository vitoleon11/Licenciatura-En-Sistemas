{Una agencia dedicada a la venta de autos ha organizado su stock y, tiene la información
de los autos en venta. Implementar un programa que:
a) Genere la información de los autos (patente, año de fabricación (2015..2024), marca,
color y modelo, finalizando con marca ‘MMM’) y los almacene en dos estructuras de
datos:
i. Una estructura eficiente para la búsqueda por patente.
ii. Una estructura eficiente para la búsqueda por marca. Para cada marca se deben
almacenar juntas las patentes y colores de los autos pertenecientes a ella.
b) Invoque a un módulo que reciba la estructura generada en a) i y una marca y retorne
la cantidad de autos de dicha marca que posee la agencia.
c) Invoque a un módulo que reciba la estructura generada en a) ii y una marca y retorne
la cantidad de autos de dicha marca que posee la agencia.
d) Invoque a un módulo que reciba el árbol generado en a) i y retorne una estructura con
la información de los autos agrupados por año de fabricación.
e) Invoque a un módulo que reciba el árbol generado en a) i y una patente y devuelva el
modelo del auto con dicha patente.
f) Invoque a un módulo que reciba el árbol generado en a) ii y una patente y devuelva el
color del auto con dicha patente.}

program practica;
type
	auto = record
		patente:string;
		anio: integer;
		marca:string;
		color:string;
		modelo:string;
	end;
	
	arbol1 = ^nodoArbol1;
	nodoArbol1 = record
		dato:auto;
		hi:arbol1;
		hd:arbol1;
	end;
	
	regLista = record
		patente:string;
		color:string;
	end;
	
	lista = ^nodoLista;
	nodoLista = record
		dato:regLista;
		sig:lista;
	end;
	
	arbol2 = ^nodoArbol2;
	nodoArbol2 = record
		marca:string;
		l:lista;
		hi:arbol2;
		hd:arbol2;
	end;
	
	lista2 = ^nodoLista2;
	nodoLista2 = record
		dato:auto;
		sig:lista2;
	end;
	
	vector = array [2015..2024] of lista2;
	
	procedure inicializarVector(var v:vector);
	var
		i:integer;
	begin
		for i := 2015 to 2024 do begin
			v[i] := nil;
		end;
	end;
	procedure agregarALista2(var l:lista2;au:auto);
	var
		nue:lista2;
	begin
		new(nue);
		nue^.dato := au;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure leerAuto(var a:auto);
	begin
		readln(a.marca);
		if (a.marca <> 'MMM') then begin
			readln(a.patente);
			readln(a.anio);
			readln(a.color);
			readln(a.modelo);
		end;
	end;
	
	
	procedure insertarArbol1(var a:arbol1;au:auto);
	begin
		if (a = nil) then begin
			new(a);
			a^.dato := au;
			a^.hi := nil;
			a^.hd := nil;
		end
		else if (au.patente < a^.dato.patente) then begin
				insertarArbol1(a^.hi,au);
			end
			else
				insertarArbol1(a^.hd,au);
	end;
	
	procedure agregarAdelante(var l:lista;r:regLista);
	var
		nue:lista;
	begin
		new(nue);
		nue^.dato := r;
		nue^.sig := l;
		l := nue;
	end;
	
	procedure insertarArbol2(var a:arbol2;au:auto);
	var
		r:regLista;
	begin
		if (a = nil) then begin
			new(a);
			a^.marca := au.marca;
			r.patente := au.patente;
			r.color := au.color;
			a^.l := nil;
			agregarAdelante(a^.l,r);
			a^.hi := nil;
			a^.hd := nil;
		end 
		else if (au.marca = a^.marca) then
				agregarAdelante(a^.l,r)
			else if (au.marca < a^.marca) then
					insertarArbol2(a^.hi,au)
				else
					insertarArbol2(a^.hd,au)
	end; 
	
	procedure cargarArboles(var a1:arbol1;var a2:arbol2);
	var
		au:auto;
	begin
		leerAuto(au);
		while (au.marca <> 'MMM') do begin
			insertarArbol1(a1,au);
			insertarArbol2(a2,au);
			leerAuto(au);
		end;
	end;
	
	//INCISO B
	function devolverMarcaArbol1(a:arbol1;marca:string):integer;
	begin
		if (a = nil) then 
			devolverMarcaArbol1 := 0
		else if (a^.dato.marca = marca) then
				devolverMarcaArbol1 := 1 + devolverMarcaArbol1(a^.hi,marca) + devolverMarcaArbol1(a^.hd,marca)
			else
				devolverMarcaArbol1 := devolverMarcaArbol1(a^.hi,marca) + devolverMarcaArbol1(a^.hd,marca);
	end;
	
	//INCISO C
	function contarEnLista(l:lista):integer;
	begin
		contarEnLista := 0;
		while (l <> nil) do begin
			contarEnLista := contarEnLista + 1;
			l := l^.sig;
		end;
	end;
	
	function devolverMarcaArbol2(a:arbol2;marca:string):integer;
	begin
		if (a = nil) then 
			devolverMarcaArbol2 := 0
		else if (a^.marca = marca) then
				devolverMarcaArbol2 := contarEnLista(a^.l)
			else if (marca < a^.marca) then
					devolverMarcaArbol2 := devolverMarcaArbol2(a^.hi,marca)
				else 
					devolverMarcaArbol2 := devolverMarcaArbol2(a^.hd,marca);
	end;
	
	//INCISO D
	procedure cargarLista2(a:arbol1;var v:vector);
	begin
		if (a <> nil) then begin
			cargarLista2(a^.hi,v);
			agregarALista2(v[a^.dato.anio],a^.dato);
			cargarLista2(a^.hd,v);
		end;
	end;
	
	//INCISO E
	function devolverModelo1(a:arbol1;patente:string):string;
	begin
		if (a = nil) then
			devolverModelo1 := 'No se encontro la patente'
		else if (a^.dato.patente = patente) then
				devolverModelo1 := a^.dato.modelo
			 else if (patente < a^.dato.patente) then
					devolverModelo1 := devolverModelo1(a^.hi,patente)
				else
					devolverModelo1(a^.hd,patente);
	end;
	
	//INCISO F
	procedure buscarEnLista(l:lista; patente:string; var color:string; var encontre:boolean);
	begin
		while (l <> nil) and (not encontre) do begin
			if (l^.dato.patente = patente) then begin
				color := l^.dato.color;
				encontre := true;
			end;
			l := l^.sig;
		end;
	end;
		
	
	procedure devolverColor(a:arbol2; patente:string; var color:string; var encontre:boolean);
	begin
		if (a <> nil) and (not encontre) then begin
			devolverColor(a^.hi, patente, color, encontre);
			if (not encontre) then
				buscarEnLista(a^.l, patente, color, encontre);
			if (not encontre) then
				devolverColor(a^.hd, patente, color, encontre);
		end;
	end;
var
	a1:arbol1;
	a2:arbol2;
begin
	cargarArboles(a1,a2);
end.
